# TruthGate Environment Variables
# Copy this file to .env and customize values as needed

# Ollama LLM model to use for classification and answer generation
# Available options: qwen3:4b, qwen3:8b, llama3.1:8b, etc.
# Default: qwen3:4b
OLLAMA_MODEL=qwen3:4b

# Optional: Refusal threshold for similarity score (0.0 to 1.0)
# Lower values = stricter (more refusals), higher values = lenient
# Default: 0.35
# REFUSAL_THRESHOLD=0.35

# Optional: Maximum number of retrieved documents before reranking
# Default: 10
# TOP_K=10

# Optional: ChromaDB persistence directory
# Default: ./db/chroma
# CHROMA_DIR=./db/chroma
